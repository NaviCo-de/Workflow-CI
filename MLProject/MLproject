name: breast-cancer-pidi

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_dir:
        type: string
        default: breast_cancer_preprocessing
      experiment_name:
        type: string
        default: breast-cancer-ci
      random_state:
        type: int
        default: 42
    command: >-
      python modelling.py
      --data-dir {data_dir}
      --experiment-name {experiment_name}
      --random-state {random_state}
